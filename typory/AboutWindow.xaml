<Window x:Class="typory.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:typory.Services"
        Title="typory"
        Width="360" SizeToContent="Height"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Background="{DynamicResource Surface}">
    <StackPanel Margin="24">

        <!-- Icon + name + version -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Image Source="pack://application:,,,/Assets/typory.ico"
                   Width="48" Height="48" />
            <StackPanel VerticalAlignment="Center" Margin="14,0,0,0">
                <TextBlock Text="typory" FontSize="20" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}" />
                <TextBlock x:Name="VersionText" FontSize="12" Foreground="{DynamicResource TextMuted}" />
            </StackPanel>
        </StackPanel>

        <TextBlock Text="{Binding [AboutDescription], Source={x:Static services:Localization.Instance}}"
                   TextAlignment="Center" TextWrapping="Wrap" Margin="0,18,0,0"
                   Foreground="{DynamicResource TextPrimary}" />

        <TextBlock Text="by Volkan Turhan" TextAlignment="Center"
                   Margin="0,14,0,0" Foreground="{DynamicResource TextMuted}" />

        <TextBlock TextAlignment="Center" Margin="0,4,0,0">
            <Hyperlink NavigateUri="https://github.com/volkanturhan/typory"
                       RequestNavigate="OnNavigate">github.com/volkanturhan/typory</Hyperlink>
        </TextBlock>

        <TextBlock TextAlignment="Center" Margin="0,2,0,0">
            <Hyperlink NavigateUri="https://volkanturhan.com"
                       RequestNavigate="OnNavigate">volkanturhan.com</Hyperlink>
        </TextBlock>

        <TextBlock Text="MIT License" TextAlignment="Center" Margin="0,4,0,0"
                   FontSize="12" Foreground="{DynamicResource TextMuted}" />

        <Button Content="{Binding [AboutClose], Source={x:Static services:Localization.Instance}}"
                Click="OnClose" Margin="0,22,0,0" Padding="22,6"
                HorizontalAlignment="Center" IsDefault="True" IsCancel="True" />
    </StackPanel>
</Window>
