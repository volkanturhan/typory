<Window x:Class="typory.ManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:typory"
        xmlns:services="clr-namespace:typory.Services"
        mc:Ignorable="d"
        Title="{Binding [ManagerTitle], Source={x:Static services:Localization.Instance}}"
        Width="540" Height="440"
        MinWidth="420" MinHeight="300"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Background="White">

    <Window.Resources>
        <SolidColorBrush x:Key="Accent" Color="#10B981" />
        <SolidColorBrush x:Key="AccentDark" Color="#059669" />
        <SolidColorBrush x:Key="TextPrimary" Color="#111827" />
        <SolidColorBrush x:Key="TextMuted" Color="#6B7280" />

        <!-- Flat rounded buttons. -->
        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource Accent}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinWidth" Value="84" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="7"
                                Background="{TemplateBinding Background}"
                                Padding="14,7">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentDark}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#D1D5DB" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- Menu bar: the same settings as the tray, so the window stands alone. -->
        <Menu DockPanel.Dock="Top" Background="#F9FAFB">
            <MenuItem Header="{Binding [TrayLanguage], Source={x:Static services:Localization.Instance}}">
                <MenuItem x:Name="EnglishMenuItem" Header="English"
                          IsCheckable="True" Click="OnEnglish" />
                <MenuItem x:Name="TurkishMenuItem" Header="Türkçe"
                          IsCheckable="True" Click="OnTurkish" />
            </MenuItem>
            <MenuItem x:Name="EnabledMenuItem" IsCheckable="True" Click="OnToggleEnabled"
                      Header="{Binding [TrayEnabled], Source={x:Static services:Localization.Instance}}" />
            <MenuItem x:Name="AutoStartMenuItem" IsCheckable="True" Click="OnToggleAutoStart"
                      Header="{Binding [TrayAutostart], Source={x:Static services:Localization.Instance}}" />
            <MenuItem Click="OnAbout"
                      Header="{Binding [TrayAbout], Source={x:Static services:Localization.Instance}}" />
        </Menu>

        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

        <!-- Header: brand mark + toolbar buttons. -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="16" Height="16" CornerRadius="4"
                        Background="{StaticResource Accent}" />
                <TextBlock Text="typory" Margin="9,0,0,0" FontWeight="SemiBold"
                           FontSize="15" Foreground="{StaticResource TextPrimary}"
                           VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="AddButton" Style="{StaticResource ToolButton}"
                        Click="OnAdd"
                        Content="{Binding [Add], Source={x:Static services:Localization.Instance}}" />
                <Button x:Name="RemoveButton" Style="{StaticResource ToolButton}"
                        Margin="8,0,0,0" Background="#9CA3AF" Click="OnRemove"
                        Content="{Binding [Remove], Source={x:Static services:Localization.Instance}}" />
            </StackPanel>
        </Grid>

        <!-- The editable list of snippets. -->
        <DataGrid x:Name="Grid" Grid.Row="1"
                  AutoGenerateColumns="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#EEF0F2"
                  BorderBrush="#E5E7EB" BorderThickness="1"
                  Background="White" RowBackground="White"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  SelectionMode="Single" SelectionUnit="FullRow"
                  RowHeight="30" FontSize="13">
            <DataGrid.Columns>
                <DataGridTextColumn Width="160"
                                    Header="{Binding [ColAbbreviation], Source={x:Static services:Localization.Instance}}"
                                    Binding="{Binding Abbreviation, UpdateSourceTrigger=LostFocus}" />
                <DataGridTextColumn Width="*"
                                    Header="{Binding [ColExpansion], Source={x:Static services:Localization.Instance}}"
                                    Binding="{Binding Expansion, UpdateSourceTrigger=LostFocus}" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Hint. -->
        <TextBlock Grid.Row="2" Margin="2,12,2,0"
                   FontSize="12" Foreground="{StaticResource TextMuted}"
                   TextWrapping="Wrap"
                   Text="{Binding [ManagerHint], Source={x:Static services:Localization.Instance}}" />
        </Grid>
    </DockPanel>
</Window>
